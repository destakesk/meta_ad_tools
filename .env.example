# ============================================================================
# metaflow — environment template
# Copy to .env and replace every CHANGEME_ placeholder. NEVER commit .env.
# Generate 32-byte base64 secrets with:  openssl rand -base64 32
# ============================================================================

# ---- Application -----------------------------------------------------------
NODE_ENV=development
APP_NAME=metaflow
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
PORT=3001

# ---- Frontend (public — inlined into client bundle) ------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# ---- Database --------------------------------------------------------------
DATABASE_URL=postgresql://metaflow:metaflow_dev@localhost:5432/metaflow_dev?schema=public
DIRECT_URL=postgresql://metaflow:metaflow_dev@localhost:5432/metaflow_dev?schema=public
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ---- Redis -----------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=metaflow:

# ---- Auth (Module 02) ------------------------------------------------------
JWT_SECRET=CHANGEME_openssl_rand_base64_32
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800

# ---- MFA (Module 02) -------------------------------------------------------
MFA_DISABLE_ALLOWED=false
MFA_TOKEN_SECRET=CHANGEME_openssl_rand_base64_32
MFA_ISSUER=Metaflow
MFA_SETUP_TOKEN_TTL_SECONDS=300
MFA_CHALLENGE_TOKEN_TTL_SECONDS=300

# ---- Token TTLs ------------------------------------------------------------
BCRYPT_COST=12
PASSWORD_RESET_TOKEN_TTL_SECONDS=3600
EMAIL_VERIFY_TOKEN_TTL_SECONDS=86400
INVITATION_TTL_SECONDS=604800

# ---- Cookies ---------------------------------------------------------------
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# ---- Email URLs (where emails link back to) --------------------------------
EMAIL_VERIFY_URL_BASE=http://localhost:3000/verify-email
PASSWORD_RESET_URL_BASE=http://localhost:3000/reset-password
INVITATION_URL_BASE=http://localhost:3000/invite/accept
EMAIL_FROM=noreply@metaflow.app

# ---- Encryption (AES-256-GCM — 32 raw bytes, base64 encoded) --------------
# Must decode to exactly 32 bytes. Used to encrypt Meta BISU tokens at rest.
ENCRYPTION_KEY=CHANGEME_openssl_rand_base64_32

# ---- Meta Marketing API (Module 04) ---------------------------------------
META_APP_ID=
META_APP_SECRET=
META_API_VERSION=v24.0
META_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/meta/callback

# ---- AI providers (Phase 2) ------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
REPLICATE_API_TOKEN=

# ---- Object storage (MinIO locally, S3 in prod) ---------------------------
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=metaflow-dev
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# ---- Observability ---------------------------------------------------------
SENTRY_DSN_WEB=
SENTRY_DSN_API=
SENTRY_ENVIRONMENT=development
LOG_LEVEL=debug

# ---- Resend (Module 02 emails) ---------------------------------------------
# If RESEND_API_KEY is empty, the EmailProcessor writes rendered HTML + links
# to tmp/mail/ for local dev / e2e tests instead of hitting the Resend API.
RESEND_API_KEY=

# ---- Rate limiting ---------------------------------------------------------
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ---- CORS ------------------------------------------------------------------
# Comma-separated allowlist of origins permitted to call the API.
CORS_ORIGINS=http://localhost:3000
