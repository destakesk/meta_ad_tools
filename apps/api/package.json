    "@types/express": "^5.0.0",
    "@types/node": "^20.17.11",
    "@types/passport": "^1.0.17",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.3",
