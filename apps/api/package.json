{
  "name": "@metaflow/api",
  "version": "0.1.0",
  "private": true,
  "description": "metaflow NestJS backend",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint . --max-warnings=0",
    "type-check": "tsc --noEmit",
