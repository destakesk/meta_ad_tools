// Prisma schema — metaflow
//
// Module 01: HealthCheck.
// Module 02: auth surface — User, Organization, Workspace, memberships, RBAC,
// Session, Invitation, AuditLog.
//
// Hashing strategy (anchor decision):
//   - bcrypt:  passwordHash, mfaBackupCodes       (user-derived, low-entropy)
//   - SHA-256: refreshTokenHash, emailVerifyToken,
//              passwordResetToken, invitation tokenHash
//              (256-bit random tokens; SHA-256 is both fast and collision-safe
//               at this entropy, and indexed DB lookup beats bcrypt iteration)

generator client {
  provider      = "prisma-client-js"
  output        = "../generated/client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================================================================
// Enums
// ==================================================================

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum WorkspaceRole {
  ADMIN
  MANAGER
  VIEWER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

// ==================================================================
// Health (Module 01)
// ==================================================================

/// HealthCheck — append-only log of service health probe results.
model HealthCheck {
  id        String   @id @default(cuid())
  service   String
  status    String
  latencyMs Int      @map("latency_ms")
  message   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([service, createdAt])
  @@map("health_checks")
}

// ==================================================================
// User
// ==================================================================

model User {
  id                     String    @id @default(cuid())
  email                  String    @unique
  emailVerifiedAt        DateTime? @map("email_verified_at")
  passwordHash           String    @map("password_hash")
  fullName               String    @map("full_name")
  avatarUrl              String?   @map("avatar_url")

  // MFA (AES-256-GCM encrypted TOTP secret; AAD = user.id)
  mfaSecret              String?   @map("mfa_secret")
  mfaEnabledAt           DateTime? @map("mfa_enabled_at")
  mfaBackupCodes         String[]  @map("mfa_backup_codes") // bcrypt hashes

  // Email verification (SHA-256 hash of opaque token)
  emailVerifyToken       String?   @map("email_verify_token")
  emailVerifyExpiresAt   DateTime? @map("email_verify_expires_at")

  // Password reset (SHA-256 hash of opaque token)
  passwordResetToken     String?   @map("password_reset_token")
  passwordResetExpiresAt DateTime? @map("password_reset_expires_at")

  // Security
  failedLoginAttempts    Int       @default(0) @map("failed_login_attempts")
  lockedUntil            DateTime? @map("locked_until")
  lastLoginAt            DateTime? @map("last_login_at")
  lastLoginIp            String?   @map("last_login_ip")

  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")
  deletedAt              DateTime? @map("deleted_at")

  sessions               Session[]
  orgMemberships         OrganizationMembership[]
  workspaceMemberships   WorkspaceMembership[]
  sentInvitations        Invitation[] @relation("InvitationSender")
  auditLogs              AuditLog[]

  @@index([email])
  @@index([emailVerifyToken])
  @@index([passwordResetToken])
  @@map("users")
}

// ==================================================================
// Tenant hierarchy
// ==================================================================

model Organization {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  workspaces  Workspace[]
  memberships OrganizationMembership[]
  invitations Invitation[]

  @@map("organizations")
}

model Workspace {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  name           String
  slug           String
  archivedAt     DateTime? @map("archived_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships    WorkspaceMembership[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("workspaces")
}

model OrganizationMembership {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  userId         String   @map("user_id")
  role           OrgRole
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_memberships")
}

model WorkspaceMembership {
  id          String        @id @default(cuid())
  workspaceId String        @map("workspace_id")
  userId      String        @map("user_id")
  role        WorkspaceRole
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId])
  @@map("workspace_memberships")
}

// ==================================================================
// Permissions + Role catalogue
// ==================================================================

model Permission {
  id          String @id @default(cuid())
  key         String @unique
  description String
  scope       String // 'organization' | 'workspace'
  createdAt   DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String @id @default(cuid())
  roleName     String @map("role_name") // 'ORG_OWNER', 'WS_ADMIN', ...
  permissionId String @map("permission_id")

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleName, permissionId])
  @@index([roleName])
  @@map("role_permissions")
}

// ==================================================================
// Sessions
// ==================================================================

model Session {
  id                String    @id @default(cuid())
  userId            String    @map("user_id")
  refreshTokenHash  String    @map("refresh_token_hash") // SHA-256 hex
  userAgent         String?   @map("user_agent")
  ipAddress         String?   @map("ip_address")
  device            String?

  expiresAt         DateTime  @map("expires_at")
  lastUsedAt        DateTime  @default(now()) @map("last_used_at")
  revokedAt         DateTime? @map("revoked_at")
  revokedReason     String?   @map("revoked_reason")

  createdAt         DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([refreshTokenHash])
  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// ==================================================================
// Invitations
// ==================================================================

model Invitation {
  id             String           @id @default(cuid())
  organizationId String           @map("organization_id")
  workspaceId    String?          @map("workspace_id")
  email          String
  role           String           // 'ORG_ADMIN' | 'ORG_MEMBER' | 'WS_ADMIN' | 'WS_MANAGER' | 'WS_VIEWER'
  tokenHash      String           @unique @map("token_hash") // SHA-256 hex
  status         InvitationStatus @default(PENDING)
  invitedById    String           @map("invited_by_id")
  expiresAt      DateTime         @map("expires_at")
  acceptedAt     DateTime?        @map("accepted_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("InvitationSender", fields: [invitedById], references: [id])

  @@index([email, status])
  @@index([tokenHash])
  @@index([organizationId, workspaceId])
  @@map("invitations")
}

// ==================================================================
// Audit log
// ==================================================================

/// Append-only log of security-sensitive events. Written async via BullMQ.
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  action     String
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}
