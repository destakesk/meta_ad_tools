// Prisma schema — metaflow
//
// Module 01: HealthCheck.
// Module 02: auth surface — User, Organization, Workspace, memberships, RBAC,
// Session, Invitation, AuditLog.
// Module 03: Meta Ads connection — MetaConnection (encrypted Meta tokens
// stored per workspace), MetaAdAccount (cached ad-account list per
// connection).
// Module 04: Campaigns + Insights — Campaign (read-through cache of Meta
// campaigns) + MetaInsightSnapshot (daily performance rows pulled from
// the Graph /insights endpoint).
//
// Hashing strategy (anchor decision):
//   - bcrypt:  passwordHash, mfaBackupCodes       (user-derived, low-entropy)
//   - SHA-256: refreshTokenHash, emailVerifyToken,
//              passwordResetToken, invitation tokenHash
//              (256-bit random tokens; SHA-256 is both fast and collision-safe
//               at this entropy, and indexed DB lookup beats bcrypt iteration)

generator client {
  provider      = "prisma-client-js"
  output        = "../generated/client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================================================================
// Enums
// ==================================================================

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum WorkspaceRole {
  ADMIN
  MANAGER
  VIEWER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum MetaConnectionStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  DELETED
  ARCHIVED
  UNKNOWN
}

enum AdSetStatus {
  ACTIVE
  PAUSED
  DELETED
  ARCHIVED
  UNKNOWN
}

enum AdStatus {
  ACTIVE
  PAUSED
  DELETED
  ARCHIVED
  UNKNOWN
}

enum CreativeKind {
  IMAGE
  VIDEO
  CAROUSEL
  LINK
  POST
}

// ==================================================================
// Health (Module 01)
// ==================================================================

/// HealthCheck — append-only log of service health probe results.
model HealthCheck {
  id        String   @id @default(cuid())
  service   String
  status    String
  latencyMs Int      @map("latency_ms")
  message   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([service, createdAt])
  @@map("health_checks")
}

// ==================================================================
// User
// ==================================================================

model User {
  id                     String    @id @default(cuid())
  email                  String    @unique
  emailVerifiedAt        DateTime? @map("email_verified_at")
  passwordHash           String    @map("password_hash")
  fullName               String    @map("full_name")
  avatarUrl              String?   @map("avatar_url")

  // MFA (AES-256-GCM encrypted TOTP secret; AAD = user.id)
  mfaSecret              String?   @map("mfa_secret")
  mfaEnabledAt           DateTime? @map("mfa_enabled_at")
  mfaBackupCodes         String[]  @map("mfa_backup_codes") // bcrypt hashes

  // Email verification (SHA-256 hash of opaque token)
  emailVerifyToken       String?   @map("email_verify_token")
  emailVerifyExpiresAt   DateTime? @map("email_verify_expires_at")

  // Password reset (SHA-256 hash of opaque token)
  passwordResetToken     String?   @map("password_reset_token")
  passwordResetExpiresAt DateTime? @map("password_reset_expires_at")

  // Security
  failedLoginAttempts    Int       @default(0) @map("failed_login_attempts")
  lockedUntil            DateTime? @map("locked_until")
  lastLoginAt            DateTime? @map("last_login_at")
  lastLoginIp            String?   @map("last_login_ip")

  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")
  deletedAt              DateTime? @map("deleted_at")

  sessions               Session[]
  orgMemberships         OrganizationMembership[]
  workspaceMemberships   WorkspaceMembership[]
  sentInvitations        Invitation[] @relation("InvitationSender")
  auditLogs              AuditLog[]

  @@index([email])
  @@index([emailVerifyToken])
  @@index([passwordResetToken])
  @@map("users")
}

// ==================================================================
// Tenant hierarchy
// ==================================================================

model Organization {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  workspaces  Workspace[]
  memberships OrganizationMembership[]
  invitations Invitation[]

  @@map("organizations")
}

model Workspace {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  name           String
  slug           String
  archivedAt     DateTime? @map("archived_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships      WorkspaceMembership[]
  metaConnections  MetaConnection[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("workspaces")
}

model OrganizationMembership {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  userId         String   @map("user_id")
  role           OrgRole
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_memberships")
}

model WorkspaceMembership {
  id          String        @id @default(cuid())
  workspaceId String        @map("workspace_id")
  userId      String        @map("user_id")
  role        WorkspaceRole
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId])
  @@map("workspace_memberships")
}

// ==================================================================
// Permissions + Role catalogue
// ==================================================================

model Permission {
  id          String @id @default(cuid())
  key         String @unique
  description String
  scope       String // 'organization' | 'workspace'
  createdAt   DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String @id @default(cuid())
  roleName     String @map("role_name") // 'ORG_OWNER', 'WS_ADMIN', ...
  permissionId String @map("permission_id")

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleName, permissionId])
  @@index([roleName])
  @@map("role_permissions")
}

// ==================================================================
// Sessions
// ==================================================================

model Session {
  id                String    @id @default(cuid())
  userId            String    @map("user_id")
  refreshTokenHash  String    @map("refresh_token_hash") // SHA-256 hex
  userAgent         String?   @map("user_agent")
  ipAddress         String?   @map("ip_address")
  device            String?

  expiresAt         DateTime  @map("expires_at")
  lastUsedAt        DateTime  @default(now()) @map("last_used_at")
  revokedAt         DateTime? @map("revoked_at")
  revokedReason     String?   @map("revoked_reason")

  createdAt         DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([refreshTokenHash])
  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// ==================================================================
// Invitations
// ==================================================================

model Invitation {
  id             String           @id @default(cuid())
  organizationId String           @map("organization_id")
  workspaceId    String?          @map("workspace_id")
  email          String
  role           String           // 'ORG_ADMIN' | 'ORG_MEMBER' | 'WS_ADMIN' | 'WS_MANAGER' | 'WS_VIEWER'
  tokenHash      String           @unique @map("token_hash") // SHA-256 hex
  status         InvitationStatus @default(PENDING)
  invitedById    String           @map("invited_by_id")
  expiresAt      DateTime         @map("expires_at")
  acceptedAt     DateTime?        @map("accepted_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("InvitationSender", fields: [invitedById], references: [id])

  @@index([email, status])
  @@index([tokenHash])
  @@index([organizationId, workspaceId])
  @@map("invitations")
}

// ==================================================================
// Meta Ads connection (Module 03)
// ==================================================================

/// MetaConnection — one row per (workspace, connected Meta business user).
///
/// Tokens are AES-256-GCM ciphertext (`v1:` prefix), with the workspaceId
/// as additional authenticated data so a leaked ciphertext can't be
/// replayed against another tenant.
model MetaConnection {
  id            String               @id @default(cuid())
  workspaceId   String               @map("workspace_id")
  metaUserId    String               @map("meta_user_id") // Facebook/Meta user id
  displayName   String               @map("display_name")
  accessToken   String               @map("access_token")    // ciphertext
  refreshToken  String?              @map("refresh_token")   // ciphertext, nullable
  scopes        String[]             @map("scopes")          // ['ads_management', ...]
  expiresAt     DateTime?            @map("expires_at")
  status        MetaConnectionStatus @default(ACTIVE)
  connectedById String               @map("connected_by_id") // user.id who completed OAuth
  lastRotatedAt DateTime?            @map("last_rotated_at")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  workspace  Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  adAccounts MetaAdAccount[]

  @@unique([workspaceId, metaUserId])
  @@index([workspaceId])
  @@index([status])
  @@map("meta_connections")
}

/// MetaAdAccount — local cache of ad accounts visible through a
/// MetaConnection. Refreshed on demand; not the source of truth.
model MetaAdAccount {
  id              String   @id @default(cuid())
  connectionId    String   @map("connection_id")
  metaAdAccountId String   @map("meta_ad_account_id") // act_xxxxx
  name            String
  currency        String
  timezone        String?
  status          String?  // ACTIVE | DISABLED | PENDING_REVIEW etc.
  syncedAt        DateTime @default(now()) @map("synced_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  connection MetaConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  campaigns  Campaign[]
  creatives  Creative[]

  @@unique([connectionId, metaAdAccountId])
  @@index([connectionId])
  @@map("meta_ad_accounts")
}

// ==================================================================
// Campaigns + Insights (Module 04)
// ==================================================================

/// Campaign — read-through cache of a Meta campaign. Budget amounts are
/// stored as integer minor units (cents/kuruş) to avoid floating-point
/// rounding across the aggregation chain.
model Campaign {
  id                  String          @id @default(cuid())
  workspaceId         String          @map("workspace_id")
  adAccountId         String          @map("ad_account_id")
  metaCampaignId      String          @map("meta_campaign_id")
  name                String
  objective           String?
  status              CampaignStatus  @default(UNKNOWN)
  dailyBudgetCents    BigInt?         @map("daily_budget_cents")
  lifetimeBudgetCents BigInt?         @map("lifetime_budget_cents")
  currency            String?
  startTime           DateTime?       @map("start_time")
  endTime             DateTime?       @map("end_time")
  syncedAt            DateTime        @default(now()) @map("synced_at")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  adAccount MetaAdAccount         @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  insights  MetaInsightSnapshot[]
  adSets    AdSet[]
  ads       Ad[]

  @@unique([adAccountId, metaCampaignId])
  @@index([workspaceId, status])
  @@index([adAccountId])
  @@map("campaigns")
}

/// AdSet — one level below Campaign. Carries its own budget, optimization
/// goal, and targeting JSON. Budgets follow the same BigInt minor-unit
/// convention as Campaign; targeting is opaque JSON because Meta's shape
/// is deep and evolves frequently.
model AdSet {
  id                  String      @id @default(cuid())
  workspaceId         String      @map("workspace_id")
  campaignId          String      @map("campaign_id")
  metaAdSetId         String      @map("meta_adset_id")
  name                String
  status              AdSetStatus @default(UNKNOWN)
  optimizationGoal    String?     @map("optimization_goal")
  billingEvent        String?     @map("billing_event")
  dailyBudgetCents    BigInt?     @map("daily_budget_cents")
  lifetimeBudgetCents BigInt?     @map("lifetime_budget_cents")
  startTime           DateTime?   @map("start_time")
  endTime             DateTime?   @map("end_time")
  targeting           Json?
  syncedAt            DateTime    @default(now()) @map("synced_at")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  campaign         Campaign                    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ads              Ad[]
  insightSnapshots MetaAdSetInsightSnapshot[]

  @@unique([campaignId, metaAdSetId])
  @@index([workspaceId, status])
  @@index([campaignId])
  @@map("ad_sets")
}

/// Ad — leaf of Meta's hierarchy. References an AdSet (targeting + budget)
/// and a Creative (the asset). Creative is nullable so an ad can be drafted
/// before a creative is attached.
model Ad {
  id              String    @id @default(cuid())
  workspaceId     String    @map("workspace_id")
  campaignId      String    @map("campaign_id")
  adsetId         String    @map("adset_id")
  creativeId      String?   @map("creative_id")
  metaAdId        String    @map("meta_ad_id")
  name            String
  status          AdStatus  @default(UNKNOWN)
  effectiveStatus String?   @map("effective_status")
  syncedAt        DateTime  @default(now()) @map("synced_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  campaign         Campaign             @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  adset            AdSet                @relation(fields: [adsetId], references: [id], onDelete: Cascade)
  creative         Creative?            @relation(fields: [creativeId], references: [id], onDelete: SetNull)
  insightSnapshots MetaAdInsightSnapshot[]

  @@unique([adsetId, metaAdId])
  @@index([workspaceId, status])
  @@index([adsetId])
  @@index([creativeId])
  @@map("ads")
}

/// Creative — ad-account-scoped asset referenced by Ads. The `objectStorySpec`
/// JSON captures Meta's full spec (link_data / video_data / photo_data / …)
/// so the UI can render a preview without another Graph call.
model Creative {
  id               String       @id @default(cuid())
  workspaceId      String       @map("workspace_id")
  adAccountId      String       @map("ad_account_id")
  metaCreativeId   String       @map("meta_creative_id")
  name             String
  kind             CreativeKind @default(IMAGE)
  thumbUrl         String?      @map("thumb_url")
  objectStorySpec  Json?        @map("object_story_spec")
  syncedAt         DateTime     @default(now()) @map("synced_at")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  adAccount MetaAdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  ads       Ad[]

  @@unique([adAccountId, metaCreativeId])
  @@index([workspaceId])
  @@index([adAccountId])
  @@map("creatives")
}

/// MetaInsightSnapshot — one row per (campaign, date). Append-only as a
/// daily roll-up; we upsert so re-syncing an already-cached range is
/// idempotent and corrects any late-arriving numbers.
model MetaInsightSnapshot {
  id          String   @id @default(cuid())
  campaignId  String   @map("campaign_id")
  date        DateTime @db.Date
  impressions BigInt   @default(0)
  clicks      BigInt   @default(0)
  spendCents  BigInt   @default(0) @map("spend_cents")
  conversions BigInt   @default(0)
  reach       BigInt   @default(0)
  frequency   Decimal  @default(0) @db.Decimal(10, 4)
  cpmCents    BigInt?  @map("cpm_cents")
  ctr         Decimal? @db.Decimal(10, 6)
  syncedAt    DateTime @default(now()) @map("synced_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date])
  @@index([campaignId, date])
  @@map("meta_insight_snapshots")
}

/// MetaAdSetInsightSnapshot — per-(adset, date) daily roll-up. Mirrors
/// MetaInsightSnapshot shape but keyed by adset so per-adset drill-down
/// stays a simple index scan.
model MetaAdSetInsightSnapshot {
  id          String   @id @default(cuid())
  adsetId     String   @map("adset_id")
  date        DateTime @db.Date
  impressions BigInt   @default(0)
  clicks      BigInt   @default(0)
  spendCents  BigInt   @default(0) @map("spend_cents")
  conversions BigInt   @default(0)
  reach       BigInt   @default(0)
  frequency   Decimal  @default(0) @db.Decimal(10, 4)
  cpmCents    BigInt?  @map("cpm_cents")
  ctr         Decimal? @db.Decimal(10, 6)
  syncedAt    DateTime @default(now()) @map("synced_at")

  adset AdSet @relation(fields: [adsetId], references: [id], onDelete: Cascade)

  @@unique([adsetId, date])
  @@index([adsetId, date])
  @@map("meta_adset_insight_snapshots")
}

/// MetaAdInsightSnapshot — per-(ad, date) daily roll-up for the leaf level.
model MetaAdInsightSnapshot {
  id          String   @id @default(cuid())
  adId        String   @map("ad_id")
  date        DateTime @db.Date
  impressions BigInt   @default(0)
  clicks      BigInt   @default(0)
  spendCents  BigInt   @default(0) @map("spend_cents")
  conversions BigInt   @default(0)
  reach       BigInt   @default(0)
  frequency   Decimal  @default(0) @db.Decimal(10, 4)
  cpmCents    BigInt?  @map("cpm_cents")
  ctr         Decimal? @db.Decimal(10, 6)
  syncedAt    DateTime @default(now()) @map("synced_at")

  ad Ad @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@unique([adId, date])
  @@index([adId, date])
  @@map("meta_ad_insight_snapshots")
}

// ==================================================================
// Audit log
// ==================================================================

/// Append-only log of security-sensitive events. Written async via BullMQ.
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  action     String
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}
