{
  "name": "@metaflow/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./generated/client/index.js"
  },
  "files": [
    "src",
    "prisma",
    "generated"
  ],
  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --skip-seed",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "lint": "eslint . --max-warnings=0",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf generated .turbo"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1"
  },
  "devDependencies": {
    "@metaflow/eslint-config": "workspace:*",
    "@metaflow/tsconfig": "workspace:*",
    "eslint": "^9.17.0",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
