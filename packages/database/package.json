{
  "name": "@metaflow/database",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": "./generated/client/index.js"
  },
  "files": [
    "dist",
    "prisma",
    "generated"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --skip-seed",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "lint": "eslint . --max-warnings=0",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf generated dist .turbo"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "prisma": "^6.2.1"
  },
  "devDependencies": {
    "@metaflow/eslint-config": "workspace:*",
    "@metaflow/tsconfig": "workspace:*",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
