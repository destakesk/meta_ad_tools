{
  "extends": "@metaflow/tsconfig/base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "outDir": "./dist",
    "verbatimModuleSyntax": false,
    "isolatedModules": false,
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "incremental": false
  },
  "include": ["src/**/*", "prisma/seed.ts", "generated/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
