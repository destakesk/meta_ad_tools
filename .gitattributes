# Force LF line endings for all text files
* text=auto eol=lf

# Explicit text types
*.ts       text eol=lf
*.tsx      text eol=lf
*.js       text eol=lf
*.jsx      text eol=lf
*.mjs      text eol=lf
*.cjs      text eol=lf
*.json     text eol=lf
*.md       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.css      text eol=lf
*.html     text eol=lf
*.sh       text eol=lf
Dockerfile text eol=lf
*.prisma   text eol=lf

# Binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.woff binary
*.woff2 binary
*.pdf  binary

# Exclude from language stats
packages/database/generated/** linguist-generated=true
**/*.min.js                    linguist-generated=true
pnpm-lock.yaml                 linguist-generated=true
