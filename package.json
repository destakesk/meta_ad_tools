{
  "name": "metaflow",
  "version": "0.1.0",
  "private": true,
  "description": "Meta Ads management platform monorepo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/destakesk/meta_ad_tools.git"
  },
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.18.2",
    "pnpm": ">=9.15.3"
  },
  "packageManager": "pnpm@9.15.3",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml,css}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml,css}\" --ignore-path .gitignore",
    "db:generate": "turbo run db:generate",
    "db:migrate": "pnpm --filter @metaflow/database db:migrate",
    "db:migrate:deploy": "pnpm --filter @metaflow/database db:migrate:deploy",
    "db:reset": "pnpm --filter @metaflow/database db:reset",
    "db:studio": "pnpm --filter @metaflow/database db:studio",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "node -e \"try{require('husky').install()}catch(e){}\""
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@types/node": "^20.17.11",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
